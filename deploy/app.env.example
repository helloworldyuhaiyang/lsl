# Backend runtime settings
# Server compose 默认使用内置 PostgreSQL。
# 如果要切到单文件 SQLite，可改成：sqlite:///./data/lsl.sqlite3
DATABASE_URL=postgresql://lsl:change_me@postgres:5432/lsl

# PostgreSQL 连接池配置；SQLite 不使用这些连接池参数。
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30

# Job runner 负责执行 ASR、脚本生成、Revision、Translation、TTS 等异步任务。
JOB_RUNNER_ENABLED=true

# runner 轮询 due jobs 的间隔，单位秒。
JOB_RUNNER_INTERVAL_SECONDS=1

# 每轮最多 claim 的 job 数，以及同时执行 job 的最大线程数。
JOB_RUNNER_BATCH_SIZE=10
JOB_RUNNER_MAX_WORKERS=4

# Asset storage
# 文件存储后端。部署联调可用 fake；真实对象存储用 oss。
STORAGE_PROVIDER=oss

# 资源读取基础 URL，后端会用 ASSET_BASE_URL + object_key 生成访问地址。
ASSET_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# 服务端上传资源到对象存储时的 HTTP 超时时间，单位秒。
ASSET_PUT_TIMEOUT=120

# STORAGE_PROVIDER=oss 时必填，用于生成 OSS 预签名上传地址。
OSS_REGION=cn-hangzhou
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# ASR
# ASR 后端。部署默认 fake；真实语音识别改成 volc。
ASR_PROVIDER=fake

# ASR_PROVIDER=volc 时必填。
VOLC_APP_KEY=
VOLC_ACCESS_KEY=

# 火山 ASR 资源、接口、模型、用户标识和 HTTP 超时配置。
VOLC_RESOURCE_ID=volc.bigasr.auc
VOLC_SUBMIT_URL=https://openspeech-direct.zijieapi.com/api/v3/auc/bigmodel/submit
VOLC_QUERY_URL=https://openspeech-direct.zijieapi.com/api/v3/auc/bigmodel/query
VOLC_MODEL_NAME=bigmodel
VOLC_UID=lsl_user
VOLC_HTTP_TIMEOUT=60

# Revision / LLM
# Revision 后端。fake 用于联调；llm 调用 OpenAI-compatible chat API。
REVISION_PROVIDER=fake

# REVISION_PROVIDER=llm 时必填 API key；base URL 和模型按供应商调整。
REVISION_LLM_API_KEY=
REVISION_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
REVISION_LLM_MODEL=doubao-seed-2-0-pro-260215

# Revision LLM HTTP 超时时间，单位秒。
REVISION_LLM_HTTP_TIMEOUT=120.0

# LLM 调试输出文件路径；空值表示不落盘。
REVISION_LLM_DEBUG_FILE=

# AI Script / LLM
# AI 脚本生成后端。无 LLM key 时可改成 fake。
SCRIPT_PROVIDER=llm

# 留空时复用 REVISION_LLM_API_KEY / BASE_URL / MODEL。
SCRIPT_LLM_API_KEY=
SCRIPT_LLM_BASE_URL=
SCRIPT_LLM_MODEL=

# Script LLM HTTP 超时时间，单位秒。
SCRIPT_LLM_HTTP_TIMEOUT=60

# Translation / LLM
# 翻译后端。fake 用于联调；llm 调用 OpenAI-compatible chat API。
TRANSLATION_PROVIDER=fake

# 留空时复用 REVISION_LLM_API_KEY / BASE_URL / MODEL。
TRANSLATION_LLM_API_KEY=
TRANSLATION_LLM_BASE_URL=
TRANSLATION_LLM_MODEL=

# Translation LLM HTTP 超时时间，单位秒。
TRANSLATION_LLM_HTTP_TIMEOUT=60

# 未显式传 target_language 时的默认翻译目标语言。
TRANSLATION_DEFAULT_TARGET_LANGUAGE=zh-CN

# TTS
# TTS 后端。fake 用于联调；真实语音合成改成 volc。
TTS_PROVIDER=fake

# 单句试听音频缓存。compose 默认连接内置 redis。
TTS_REDIS_URL=redis://redis:6379/0

# 单句试听缓存 TTL，单位秒。
TTS_CACHE_TTL_SECONDS=7200

# TTS_PROVIDER=volc 时必填。
TTS_VOLC_APP_ID=
TTS_VOLC_ACCESS_KEY=

# 火山 TTS 资源、接口和 HTTP 超时配置。
TTS_VOLC_RESOURCE_ID=seed-tts-2.0
TTS_VOLC_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
TTS_VOLC_HTTP_TIMEOUT=60

# session 没有保存 TTS 设置时使用的默认格式和合成参数。
TTS_DEFAULT_FORMAT=mp3
TTS_DEFAULT_EMOTION_SCALE=4.0
TTS_DEFAULT_SPEECH_RATE=0.0
TTS_DEFAULT_LOUDNESS_RATE=0.0
